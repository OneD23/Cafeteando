{
  "expo": {
    "name": "CaféTrack Mobile",
    "slug": "cafetrack-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0f0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cafetrack.mobile"
    },
    "android": {
      "package": "com.cafetrack.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0f0a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir a CaféTrack acceder a la cámara."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4eb6171d-a2e6-4914-9a1f-b935e21c72b5"
      }
    }
  }
}
